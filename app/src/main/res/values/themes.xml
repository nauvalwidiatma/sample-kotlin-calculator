<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.SimpleCalculator" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:statusBarColor" tools:targetApi="l">#F4F7FB</item>
    </style>

    <style name="Widget.SimpleCalculator.ButtonBase" parent="Widget.Material3.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:minHeight">72dp</item>
        <item name="backgroundTint">#FFFFFF</item>
        <item name="android:textColor">#0F172A</item>
    </style>

    <style name="Widget.SimpleCalculator.ButtonAccent" parent="Widget.SimpleCalculator.ButtonBase">
        <item name="backgroundTint">#E2E8F0</item>
    </style>

    <style name="Widget.SimpleCalculator.ButtonPrimary" parent="Widget.SimpleCalculator.ButtonBase">
        <item name="backgroundTint">#0F766E</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>
</resources>
